<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - GEEOOH HOTEL Admin</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #f5f7fa; }
        
        /* Sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 260px;
            height: 100%;
            background: #1a2a3a;
            color: white;
            z-index: 1000;
        }
        
        .sidebar-header {
            padding: 25px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        
        .sidebar-header h3 { color: #c5a028; margin: 0; }
        .sidebar-header p { font-size: 0.75rem; opacity: 0.7; margin: 5px 0 0; }
        
        .sidebar-nav { padding: 20px 15px; }
        
        .nav-item {
            display: block;
            padding: 12px 15px;
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s;
        }
        
        .nav-item:hover { background: rgba(197, 160, 40, 0.2); color: #c5a028; }
        .nav-item i { width: 25px; margin-right: 10px; }
        
        .sidebar-user {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
        
        .logout-btn {
            width: 100%;
            background: rgba(220, 53, 69, 0.2);
            border: none;
            color: #dc3545;
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
        }
        
        .logout-btn:hover { background: #dc3545; color: white; }
        
        /* Main Content */
        .main-content { margin-left: 260px; padding: 20px; }
        
        .welcome-section {
            background: white;
            border-radius: 20px;
            padding: 25px 30px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }
        
        .welcome-text h2 { font-size: 1.5rem; color: #1a2a3a; margin: 0; }
        .welcome-text h2 span { color: #c5a028; }
        
        .mobile-toggle {
            display: none;
            position: fixed;
            top: 15px;
            left: 15px;
            z-index: 1001;
            background: #1a2a3a;
            border: none;
            color: white;
            font-size: 1.5rem;
            padding: 10px 15px;
            border-radius: 8px;
            cursor: pointer;
        }
        
        @media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); transition: all 0.3s; }
            .sidebar.active { transform: translateX(0); }
            .main-content { margin-left: 0; }
            .mobile-toggle { display: block; }
        }
    </style>
</head>
<body>

    <button class="mobile-toggle" id="mobileToggle">
        <i class="fas fa-bars"></i>
    </button>
    
    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <h3>GEEOOH HOTEL</h3>
            <p>Administrator Panel</p>
        </div>
        
        <div class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item">
                <i class="fas fa-chart-line"></i> Dashboard
            </a>
            <a href="/admin/rooms" class="nav-item">
                <i class="fas fa-bed"></i> Rooms
            </a>
            <a href="/admin/bookings" class="nav-item">
                <i class="fas fa-calendar-check"></i> Bookings
            </a>
            <a href="/admin/guests" class="nav-item">
                <i class="fas fa-users"></i> Guests
            </a>
            <a href="/admin/reports" class="nav-item">
                <i class="fas fa-chart-bar"></i> Reports
            </a>
            <a href="/admin/settings" class="nav-item">
                <i class="fas fa-cog"></i> Settings
            </a>
        </div>
        
        <div class="sidebar-user">
            <div class="user-name" style="margin-bottom: 15px;">
                <i class="fas fa-user-circle"></i> <%= user ? user.first_name + ' ' + user.last_name : 'Admin' %>
            </div>
            <form action="/api/auth/logout" method="POST">
                <button type="submit" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </form>
        </div>
    </div>
    
    <div class="main-content">
        <div class="welcome-section">
            <div class="welcome-text">
                <h2>Welcome back, <span><%= user ? user.first_name : 'Admin' %></span>!</h2>
                <p>Here's what's happening with your hotel today.</p>
            </div>
        </div>
        <%- body %>
    </div>
    
    <script>
        const mobileToggle = document.getElementById('mobileToggle');
        const sidebar = document.getElementById('sidebar');
        if (mobileToggle) {
            mobileToggle.addEventListener('click', () => {
                sidebar.classList.toggle('active');
            });
        }
    </script>
</body>
</html>