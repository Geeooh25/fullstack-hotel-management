<%
function getStatusClass(status) {
    return status === 'active' ? 'success' : 'danger';
}
%>

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Guest Management</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover" id="guestsTable">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Total Stays</th>
                        <th>Total Spent</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% guests.forEach(guest => { %>
                    <tr>
                        <td><strong><%= guest.first_name %> <%= guest.last_name %></strong></td>
                        <td><%= guest.email %></td>
                        <td><%= guest.phone || 'N/A' %></td>
                        <td><%= guest.total_stays %></td>
                        <td>$<%= guest.total_spent %></td>
                        <td><%= new Date(guest.created_at).toLocaleDateString() %></td>
                        <td>
                            <a href="/admin/guests/<%= guest.id %>" class="btn btn-sm btn-info">
                                <i class="fas fa-eye"></i>
                            </a>
                            <button onclick="toggleBlacklist(<%= guest.id %>, <%= guest.is_blacklisted %>)" class="btn btn-sm <%= guest.is_blacklisted ? 'btn-success' : 'btn-warning' %>">
                                <i class="fas <%= guest.is_blacklisted ? 'fa-check' : 'fa-ban' %>"></i>
                            </button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {
        $('#guestsTable').DataTable({
            pageLength: 25,
            order: [[5, 'desc']],
            language: {
                search: "Search guests:",
                lengthMenu: "Show _MENU_ guests"
            }
        });
    });
    
    function toggleBlacklist(guestId, isBlacklisted) {
        const action = isBlacklisted ? 'remove from' : 'add to';
        if (confirm(`Are you sure you want to ${action} blacklist?`)) {
            fetch(`/api/admin/guests/${guestId}/blacklist`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ blacklisted: !isBlacklisted })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.error || 'Failed to update blacklist status');
                }
            });
        }
    }
</script>