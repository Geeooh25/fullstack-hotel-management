<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">Room Status</h5>
            </div>
            <div class="card-body">
                <div class="list-group">
                    <% rooms.forEach(room => { %>
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>Room <%= room.room_number %></strong>
                            <br>
                            <small class="text-muted"><%= room.RoomType ? room.RoomType.name : '' %></small>
                        </div>
                        <div>
                            <span class="badge bg-<%= getRoomStatusClass(room.status) %>">
                                <%= room.status %>
                            </span>
                            <button onclick="updateRoomStatus(<%= room.id %>, 'cleaning')" class="btn btn-sm btn-primary mt-1">
                                <i class="fas fa-broom"></i> Clean
                            </button>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-white">
                <h5 class="mb-0">Housekeeping Tasks</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Room</th>
                                <th>Status</th>
                                <th>Assigned To</th>
                                <th>Started</th>
                                <th>Completed</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% housekeepingTasks.forEach(task => { %>
                            <tr>
                                <td>Room <%= task.Room.room_number %></td>
                                <td>
                                    <span class="badge bg-<%= task.status === 'completed' ? 'success' : 'warning' %>">
                                        <%= task.status %>
                                    </span>
                                </td>
                                <td><%= task.assigned_to || 'Unassigned' %></td>
                                <td><%= task.started_at ? new Date(task.started_at).toLocaleTimeString() : '-' %></td>
                                <td><%= task.completed_at ? new Date(task.completed_at).toLocaleTimeString() : '-' %></td>
                                <td>
                                    <% if (task.status !== 'completed') { %>
                                        <button onclick="completeTask(<%= task.id %>)" class="btn btn-sm btn-success">
                                            <i class="fas fa-check"></i> Complete
                                        </button>
                                    <% } %>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function updateRoomStatus(roomId, status) {
        fetch(`/api/admin/rooms/${roomId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: status })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to update room status');
            }
        });
    }
    
    function completeTask(taskId) {
        fetch(`/api/admin/housekeeping/${taskId}/complete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to complete task');
            }
        });
    }
</script>