<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Service Requests - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        .sidebar { position: fixed; top: 0; left: 0; height: 100vh; width: 250px; background: #1a2a3a; color: white; padding: 1rem; }
        .sidebar a { color: white; text-decoration: none; display: block; padding: 0.75rem; margin: 0.25rem 0; border-radius: 8px; }
        .sidebar a:hover, .sidebar a.active { background: var(--gold, #B8860B); }
        .main-content { margin-left: 250px; padding: 2rem; }
        .request-card { border: 1px solid #ddd; border-radius: 8px; padding: 1rem; margin-bottom: 1rem; }
        .status-pending { background: #ffc107; color: #000; padding: 0.25rem 0.5rem; border-radius: 4px; }
        .status-contacted { background: #17a2b8; color: white; }
        .status-completed { background: #28a745; color: white; }
        .status-cancelled { background: #dc3545; color: white; }
    </style>
</head>
<body>
    <div class="sidebar">
        <h4 class="mb-4">GEEOOH Admin</h4>
        <a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
        <a href="/admin/bookings"><i class="fas fa-calendar-check"></i> Bookings</a>
        <a href="/admin/rooms"><i class="fas fa-bed"></i> Rooms</a>
        <a href="/admin/amenities"><i class="fas fa-concierge-bell"></i> Amenities</a>
        <a href="/admin/menu"><i class="fas fa-utensils"></i> Menu</a>
        <a href="/admin/requests" class="active"><i class="fas fa-envelope"></i> Requests</a>
        <a href="/admin/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
    
    <div class="main-content">
        <h1 class="mb-4">Service Requests</h1>
        
        <% requests.forEach(request => { %>
            <div class="request-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h5><%= request.amenity.name %> Request</h5>
                        <p><strong>Guest:</strong> <%= request.guest_name %> (<%= request.guest_email %>)</p>
                        <p><strong>Phone:</strong> <%= request.guest_phone %></p>
                        <% if (request.booking_reference) { %>
                            <p><strong>Booking:</strong> <%= request.booking_reference %></p>
                        <% } %>
                        <p><strong>Details:</strong> <%= request.request_details || 'N/A' %></p>
                        <% if (request.preferred_date) { %>
                            <p><strong>Preferred Date:</strong> <%= new Date(request.preferred_date).toLocaleString() %></p>
                        <% } %>
                        <p><strong>Submitted:</strong> <%= new Date(request.created_at).toLocaleString() %></p>
                    </div>
                    <div>
                        <select class="form-control status-select" data-id="<%= request.id %>">
                            <option value="pending" <%= request.status === 'pending' ? 'selected' : '' %>>Pending</option>
                            <option value="contacted" <%= request.status === 'contacted' ? 'selected' : '' %>>Contacted</option>
                            <option value="completed" <%= request.status === 'completed' ? 'selected' : '' %>>Completed</option>
                            <option value="cancelled" <%= request.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                        </select>
                    </div>
                </div>
            </div>
        <% }); %>
        
        <% if (requests.length === 0) { %>
            <div class="text-center py-5">
                <i class="fas fa-inbox" style="font-size: 3rem; color: #ccc;"></i>
                <p>No requests yet</p>
            </div>
        <% } %>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelectorAll('.status-select').forEach(select => {
            select.addEventListener('change', async (e) => {
                const id = e.target.dataset.id;
                const status = e.target.value;
                await fetch(`/api/requests/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status })
                });
            });
        });
    </script>
</body>
</html>